---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import EntryLayout from "../../layouts/EntryLayout.astro";

export async function getStaticPaths() {
  const artworks = await getCollection("artworks");

  return artworks.map((entry: CollectionEntry<"artworks">) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

interface Props {
  entry: CollectionEntry<"artworks">;
}

const { entry } = Astro.props as Props;
const { Content } = await entry.render();

const details = [
  { label: "Medium", value: entry.data.medium },
  { label: "Palette", value: entry.data.palette.join(", ") },
  ...(entry.data.dimensions ? [{ label: "Size", value: entry.data.dimensions }] : [])
];
---

<EntryLayout entry={entry} sectionLabel="Artworks" sectionHref="/artworks" details={details}>
  <Content />
</EntryLayout>
